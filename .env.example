# ─────────────────────────────────────────────────────────────────────────────
# RAG Radiology Report Generation — Environment Variables
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is listed in .gitignore.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Project paths ─────────────────────────────────────────────────────────────

# Absolute path to the project root directory.
# Example: /Users/yourname/projects/rag-rrg
PROJECT_ROOT=/path/to/your/rag-rrg


# ── HuggingFace ───────────────────────────────────────────────────────────────

# Required to download BioMedCLIP (microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224).
# Get a free token at https://huggingface.co/settings/tokens
# The model is gated — you must accept its license on the HuggingFace model page first.
HUGGINGFACE_TOKEN=hf_your_token_here


# ── Embedding model ───────────────────────────────────────────────────────────

# BioMedCLIP model identifier (do not change — vit_large_patch14 does not exist).
BIOMEDCLIP_MODEL=hf-hub:microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224

# Shared vector space dimension for image and text embeddings.
EMBEDDING_DIM=512


# ── Data paths ────────────────────────────────────────────────────────────────

# All paths are relative to PROJECT_ROOT.
DATA_DIR=data
KNOWLEDGE_BASE_CSV=data/knowledge_base.csv
TEST_DATASET_CSV=data/test_dataset.csv

# Base directory where MIMIC-CXR image files live.
# Full image path = IMAGE_BASE_DIR / image_path_from_csv
IMAGE_BASE_DIR=data


# ── Embedding and indexing paths ──────────────────────────────────────────────

EMBEDDING_DIR=src/embedding
INDEXING_DIR=src/indexing

# FAISS index type — IndexFlatIP uses exact cosine similarity search.
# Switch to IndexIVFFlat if the dataset grows beyond ~500K vectors.
FAISS_INDEX_TYPE=IndexFlatIP
FAISS_INDEX_FILE=src/indexing/faiss_image_index.bin
INDEX_CONFIG_FILE=src/indexing/index_config.json


# ── Retrieval config ──────────────────────────────────────────────────────────

# Number of similar cases to retrieve per query image.
DEFAULT_TOP_K=5

# Batch size for embedding generation (reduce to 2 if you hit OOM).
CHUNK_SIZE=10000

# RAM usage threshold — subprocess architecture kicks in above this percentage.
# Set higher (88%) on Apple Silicon where macOS baseline is ~3.5GB.
RAM_LIMIT_PERCENT=88.0


# ── Generation backend ────────────────────────────────────────────────────────

# Which LLM backend to use for report generation.
# "gemini" → tries Gemini first, falls back to Groq on failure.
# "groq"   → skips Gemini, goes straight to Groq.
GENERATION_BACKEND=groq


# ── Groq API (free tier — primary generation backend) ─────────────────────────

# Get a free API key at https://console.groq.com — no billing required.
# Vision model used: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_KEY=your_groq_api_key_here


# ── Google Gemini API (free tier — fallback generation backend) ───────────────

# Get a free API key at https://aistudio.google.com — no credit card required.
# Free tier: 15 RPM, 1500 RPD for Gemini Flash.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash


# ── Evaluation ────────────────────────────────────────────────────────────────

GENERATION_OUTPUT_DIR=data/generated_reports

# Minimum word count for a ground truth report to be included in evaluation.
# Reports shorter than this are typically comparative stubs ("unchanged").
MIN_GT_WORD_COUNT=30


# ── Logging ───────────────────────────────────────────────────────────────────

LOG_DIR=logs
LOG_LEVEL=INFO


# ── API server (for local dev and Render deployment) ─────────────────────────

# Port for the FastAPI server. Render sets $PORT automatically.
PORT=8000

# Set to the Render disk mount path when deploying to Render.
# Leave empty for local development — paths resolve from PROJECT_ROOT.
# Example on Render: DATA_MOUNT=/mnt/rag-data
DATA_MOUNT=
